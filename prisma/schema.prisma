generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                         String         @id @default(cuid())
  email                      String         @unique
  password                   String
  firstName                  String
  lastName                   String
  role                       UserRole       @default(EMPLOYEE)
  phone                      String?
  nationalId                 String?
  dateOfBirth                DateTime?
  gender                     String?
  profilePicture             String?
  username                   String?
  changePasswordOnFirstLogin Boolean        @default(false)
  accountStatus              Boolean        @default(true)
  accountEndDate             DateTime?
  department                 String?
  position                   String?
  workplace                  String?
  manager                    String?
  startDate                  DateTime?
  description                String?
  locale                     Locale         @default(TR)
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  is_active                  Boolean        @default(true)
  deletedAt                  DateTime?
  activityLogs               ActivityLog[]
  appointments               Appointment[]
  notifications              Notification[]
  assignedTickets            Ticket[]       @relation("AssignedTickets")

  @@index([deletedAt])
}

model Customer {
  id                String        @id @default(cuid())
  firstName         String
  lastName          String
  email             String?
  phone             String?
  street            String?
  city              String?
  postalCode        String?
  taxOffice         String?
  taxNumber         String?
  responsiblePerson String?
  customerGroup     String?
  sector            String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  is_active         Boolean       @default(true)
  deletedAt         DateTime?
  appointments      Appointment[]
  invoices          Invoice[]
  orders            Order[]
  tickets           Ticket[]

  @@index([deletedAt])
  @@index([lastName])
  @@index([email])
  @@index([customerGroup])
}

model Ticket {
  id                String             @id @default(cuid())
  customerId        String
  assignedUserId    String?
  title             String
  description       String?
  category          TicketCategory
  priority          TicketPriority
  status            TicketStatus       @default(NEW)
  source            TicketSource
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  aiSummary         String?
  aiConfidence      Float?
  aiCategory        String?
  aiSuggestedTitle  String?
  aiExtractedData   Json?
  aiProcessedAt     DateTime?
  is_active         Boolean            @default(true)
  deletedAt         DateTime?
  aiConversationLog AIConversationLog?
  emails            EmailInbox[]
  phoneCalls        PhoneCall[]
  assignedUser      User?              @relation("AssignedTickets", fields: [assignedUserId], references: [id])
  customer          Customer           @relation(fields: [customerId], references: [id])
  webChatSessions   WebChatSession[]
  whatsappMessages  WhatsAppMessage[]

  @@index([deletedAt])
  @@index([customerId])
  @@index([assignedUserId])
  @@index([status])
  @@index([priority])
}

model Appointment {
  id          String            @id @default(cuid())
  customerId  String
  employeeId  String?
  title       String
  description String?
  status      AppointmentStatus @default(PLANNED)
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  is_active   Boolean           @default(true)
  deletedAt   DateTime?
  employee    User?             @relation(fields: [employeeId], references: [id])
  customer    Customer          @relation(fields: [customerId], references: [id])

  @@index([deletedAt])
  @@index([customerId])
  @@index([employeeId])
  @@index([startAt])
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

model EmailInbox {
  id              String   @id @default(cuid())
  messageId       String   @unique
  fromEmail       String
  fromName        String?
  subject         String
  body            String
  processed       Boolean  @default(false)
  processingError String?
  ticketId        String?
  createdAt       DateTime @default(now())
  ticket          Ticket?  @relation(fields: [ticketId], references: [id])

  @@index([processed])
  @@index([createdAt])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String?
  title      String
  message    String?
  type       NotificationType
  isRead     Boolean          @default(false)
  entityType String?
  entityId   String?
  createdAt  DateTime         @default(now())
  user       User?            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AIConversationLog {
  id                  String            @id @default(cuid())
  ticketId            String?           @unique
  channelType         TicketSource
  conversationType    ConversationType
  startTime           DateTime
  endTime             DateTime?
  audioRecordingUrl   String?
  chatLog             Json?
  originalEmailId     String?
  aiIntent            String?
  aiConfidence        Float?
  aiExtractedEntities Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  ticket              Ticket?           @relation(fields: [ticketId], references: [id])
  phoneCalls          PhoneCall[]
  webChatSessions     WebChatSession[]
  whatsappMessages    WhatsAppMessage[]

  @@index([ticketId])
  @@index([channelType])
  @@index([createdAt])
}

model WhatsAppMessage {
  id                String             @id @default(cuid())
  conversationLogId String?
  ticketId          String?
  phoneNumber       String
  messageFrom       String
  content           String
  mediaUrl          String?
  mediaType         String?
  whatsappMessageId String             @unique
  createdAt         DateTime           @default(now())
  ticket            Ticket?            @relation(fields: [ticketId], references: [id])
  conversationLog   AIConversationLog? @relation(fields: [conversationLogId], references: [id])

  @@index([ticketId])
  @@index([phoneNumber])
  @@index([createdAt])
}

model PhoneCall {
  id                String             @id @default(cuid())
  conversationLogId String?
  ticketId          String?
  phoneNumber       String
  direction         CallDirection
  duration          Int?
  recordingUrl      String?
  transcription     String?
  callStatus        CallStatus
  createdAt         DateTime           @default(now())
  ticket            Ticket?            @relation(fields: [ticketId], references: [id])
  conversationLog   AIConversationLog? @relation(fields: [conversationLogId], references: [id])

  @@index([ticketId])
  @@index([phoneNumber])
  @@index([createdAt])
}

model WebChatSession {
  id                String             @id @default(cuid())
  conversationLogId String?
  ticketId          String?
  sessionId         String             @unique
  customerEmail     String?
  customerName      String?
  ipAddress         String?
  userAgent         String?
  status            ChatStatus
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  ticket            Ticket?            @relation(fields: [ticketId], references: [id])
  conversationLog   AIConversationLog? @relation(fields: [conversationLogId], references: [id])

  @@index([ticketId])
  @@index([sessionId])
  @@index([createdAt])
}

model Bank {
  id           String        @id @default(cuid())
  name         String
  address      String
  email        String
  phoneNumber  String
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime      @default(now())
  createdBy    String?
  updatedAt    DateTime      @updatedAt
  updatedBy    String?
  bankAccounts BankAccount[]

  @@index([deletedAt])
}

model BankAccount {
  id           String    @id @default(cuid())
  bankId       String
  currencyId   String
  currencyCode String
  iban         String
  swiftNumber  String
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime  @default(now())
  createdBy    String?
  updatedAt    DateTime  @updatedAt
  updatedBy    String?
  currency     Currency  @relation(fields: [currencyId], references: [id])
  bank         Bank      @relation(fields: [bankId], references: [id])

  @@index([deletedAt])
  @@index([bankId])
  @@index([currencyId])
}

model CustomerAuthority {
  id        String    @id @default(cuid())
  name      String
  email     String
  title     String
  gsm       String
  phone     String
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  @@index([deletedAt])
}

model Employee {
  id           String      @id @default(cuid())
  name         String
  email        String
  phoneNumber  String
  address      String?
  departmentId String?
  isDeleted    Boolean     @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime    @default(now())
  createdBy    String?
  updatedAt    DateTime    @updatedAt
  updatedBy    String?
  department   Department? @relation(fields: [departmentId], references: [id])

  @@index([deletedAt])
  @@index([departmentId])
}

model TaxOffice {
  id                 String    @id @default(cuid())
  plateCode          String
  name               String
  districtName       String
  muhasebeBirimiKodu String    @unique
  taxOfficeName      String
  isDeleted          Boolean   @default(false)
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime  @default(now())
  createdBy          String?
  updatedAt          DateTime  @updatedAt
  updatedBy          String?

  @@index([deletedAt])
  @@index([plateCode])
  @@index([muhasebeBirimiKodu])
}

model Department {
  id        String     @id @default(cuid())
  name      String
  isActive  Boolean    @default(true)
  isDeleted Boolean    @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime   @default(now())
  createdBy String?
  updatedAt DateTime   @updatedAt
  updatedBy String?
  employees Employee[]

  @@index([deletedAt])
}

model CustomerType {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  @@index([deletedAt])
}

model CargoFirm {
  id          String    @id @default(cuid())
  name        String
  email       String
  phoneNumber String
  address     String
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?

  @@index([deletedAt])
}

model SaleType {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  @@index([deletedAt])
}

model Currency {
  id           String        @id @default(cuid())
  code         String        @unique
  name         String
  symbol       String
  isActive     Boolean       @default(true)
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  deletedBy    String?
  createdAt    DateTime      @default(now())
  createdBy    String?
  updatedAt    DateTime      @updatedAt
  updatedBy    String?
  bankAccounts BankAccount[]

  @@index([deletedAt])
}

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?
  products    Product[]

  @@index([deletedAt])
}

model Product {
  id             String           @id @default(cuid())
  code           String           @unique
  name           String
  description    String?
  categoryId     String?
  unit           ProductUnit      @default(PIECE)
  purchasePrice  String?
  salePrice      String
  taxRate        String           @default("0")
  currentStock   Int              @default(0)
  minStock       Int              @default(0)
  maxStock       Int?
  barcode        String?
  imageUrl       String?
  isActive       Boolean          @default(true)
  isDeleted      Boolean          @default(false)
  deletedAt      DateTime?
  deletedBy      String?
  createdAt      DateTime         @default(now())
  createdBy      String?
  updatedAt      DateTime         @updatedAt
  updatedBy      String?
  invoiceItems   InvoiceItem[]
  orderItems     OrderItem[]
  category       ProductCategory? @relation(fields: [categoryId], references: [id])
  stockMovements StockMovement[]

  @@index([categoryId])
  @@index([deletedAt])
}

model StockMovement {
  id            String            @id @default(cuid())
  productId     String
  type          StockMovementType
  quantity      Int
  stockBefore   Int
  stockAfter    Int
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime          @default(now())
  createdBy     String?
  product       Product           @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([createdAt])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  customerId      String
  orderDate       DateTime      @default(now())
  deliveryDate    DateTime?
  status          OrderStatus   @default(DRAFT)
  paymentStatus   PaymentStatus @default(UNPAID)
  subtotal        String
  taxAmount       String        @default("0")
  discountAmount  String        @default("0")
  shippingCost    String        @default("0")
  totalAmount     String
  shippingAddress String?
  billingAddress  String?
  notes           String?
  isActive        Boolean       @default(true)
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime      @default(now())
  createdBy       String?
  updatedAt       DateTime      @updatedAt
  updatedBy       String?
  invoices        Invoice[]
  customer        Customer      @relation(fields: [customerId], references: [id])
  orderItems      OrderItem[]

  @@index([customerId])
  @@index([orderDate])
  @@index([status])
  @@index([deletedAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  quantity    Int
  unitPrice   String
  taxRate     String   @default("0")
  discount    String   @default("0")
  subtotal    String
  taxAmount   String
  totalAmount String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  customerId      String
  orderId         String?
  invoiceDate     DateTime      @default(now())
  dueDate         DateTime?
  status          InvoiceStatus @default(DRAFT)
  subtotal        String
  taxAmount       String        @default("0")
  discountAmount  String        @default("0")
  totalAmount     String
  paidAmount      String        @default("0")
  remainingAmount String
  billingAddress  String?
  shippingAddress String?
  notes           String?
  emailSent       Boolean       @default(false)
  emailSentAt     DateTime?
  isActive        Boolean       @default(true)
  isDeleted       Boolean       @default(false)
  deletedAt       DateTime?
  deletedBy       String?
  createdAt       DateTime      @default(now())
  createdBy       String?
  updatedAt       DateTime      @updatedAt
  updatedBy       String?
  order           Order?        @relation(fields: [orderId], references: [id])
  customer        Customer      @relation(fields: [customerId], references: [id])
  invoiceItems    InvoiceItem[]
  payments        Payment[]

  @@index([customerId])
  @@index([orderId])
  @@index([invoiceDate])
  @@index([status])
  @@index([deletedAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String
  description String
  quantity    Int
  unitPrice   String
  taxRate     String   @default("0")
  discount    String   @default("0")
  subtotal    String
  taxAmount   String
  totalAmount String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product  @relation(fields: [productId], references: [id])
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id            String    @id @default(cuid())
  invoiceId     String
  paymentDate   DateTime  @default(now())
  amount        String
  paymentMethod String
  reference     String?
  notes         String?
  isActive      Boolean   @default(true)
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime  @default(now())
  createdBy     String?
  updatedAt     DateTime  @updatedAt
  updatedBy     String?
  invoice       Invoice   @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@index([paymentDate])
  @@index([deletedAt])
}

model CommissionRule {
  id                String            @id @default(cuid())
  name              String
  description       String?
  commissionType    CommissionType    @default(PERCENTAGE)
  commissionRate    String            @default("0")
  fixedAmount       String            @default("0")
  productCategoryId String?
  salesTarget       String            @default("0")
  calculationPeriod CalculationPeriod @default(MONTHLY)
  effectiveDate     DateTime          @default(now())
  expiryDate        DateTime?
  isActive          Boolean           @default(true)
  isDeleted         Boolean           @default(false)
  deletedAt         DateTime?
  deletedBy         String?
  createdAt         DateTime          @default(now())
  createdBy         String?
  updatedAt         DateTime          @updatedAt
  updatedBy         String?
  tiers             CommissionTier[]

  @@index([deletedAt])
  @@index([effectiveDate])
}

model CommissionTier {
  id               String         @id @default(cuid())
  commissionRuleId String
  minValue         String         @default("0")
  maxValue         String?
  commissionRate   String
  order            Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  commissionRule   CommissionRule @relation(fields: [commissionRuleId], references: [id], onDelete: Cascade)

  @@index([commissionRuleId])
}

enum UserRole {
  ADMIN
  SUPERVISOR
  MANAGER
  EMPLOYEE
}

enum TicketStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  HEATING
  PLUMBING
  ELECTRICITY
  PAINTING
  OTHER
}

enum TicketSource {
  WEB_CHAT
  PHONE
  WHATSAPP
  EMAIL
}

enum AppointmentStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum Locale {
  EN
  DE
  FR
  RU
  TR
}

enum ConversationType {
  INITIAL_INQUIRY
  INFORMATION_GATHERING
  APPOINTMENT_SCHEDULING
  ISSUE_RESOLUTION
  FOLLOW_UP
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  COMPLETED
  MISSED
  CANCELLED
}

enum ChatStatus {
  ACTIVE
  CLOSED
  TRANSFERRED
}

enum ProductUnit {
  PIECE
  KG
  M
  M2
  M3
  LT
  SET
  BOX
  PACKAGE
}

enum StockMovementType {
  IN
  OUT
  TRANSFER
  ADJUSTMENT
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum CommissionType {
  PERCENTAGE
  FIXED
  TIERED
}

enum CalculationPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}
