datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

enum UserRole {
  ADMIN
  SUPERVISOR
  MANAGER
  EMPLOYEE
}

model Company {
  id        String   @id @default(cuid())
  name      String
  
  // Fatura bilgileri
  taxId     String?  // Vergi numarası
  taxOffice String?  // Vergi dairesi
  
  // İletişim bilgileri
  email     String?
  phone     String?
  website   String?
  
  // Adres bilgileri
  street    String?
  city      String?
  postalCode String?
  country   String?
  
  // Banka bilgileri
  bankName  String?
  iban      String?
  
  // Logo
  logoUrl   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  customers     Customer[]
  tickets       Ticket[]
  appointments  Appointment[]
  emails        EmailInbox[]
  activityLogs  ActivityLog[]
  notifications Notification[]

  // AI Assistant
  whatsappMessages WhatsAppMessage[]
  phoneCalls        PhoneCall[]
  webChatSessions   WebChatSession[]
  aiConversationLogs AIConversationLog[]

  // AI asistan konfigürasyonu
  aiConfig Json?

  is_active  Boolean   @default(true)
  deletedAt DateTime?
  @@index([deletedAt])
}

/**
 * User
 */

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      UserRole @default(EMPLOYEE)

  companyId       String
  company         Company         @relation(fields: [companyId], references: [id])
  assignedTickets Ticket[]        @relation("AssignedTickets")
  appointments    Appointment[]
  activityLogs    ActivityLog[]
  notifications   Notification[]

  locale Locale @default(TR)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  is_active  Boolean   @default(true)
  deletedAt DateTime? 
  @@index([deletedAt])
  @@index([companyId])
}

model Customer {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  firstName String
  lastName  String

  email String?
  phone String?

  street     String?
  city       String?
  postalCode String?

  // Vergi bilgileri
  taxOffice String?
  taxNumber String?

  // Müşteri detayları
  responsiblePerson String?
  customerGroup      String?
  sector             String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets      Ticket[]
  appointments Appointment[]
  orders       Order[]

  is_active  Boolean   @default(true)
  deletedAt DateTime? 

  @@index([deletedAt])
  @@index([companyId])
  @@index([lastName])
  @@index([email])
  @@index([customerGroup])
}

model Ticket {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  assignedUserId String?
  assignedUser   User?   @relation("AssignedTickets", fields: [assignedUserId], references: [id])

  title       String
  description String?

  category TicketCategory
  priority TicketPriority
  status   TicketStatus   @default(NEW)
  source   TicketSource

  emails EmailInbox[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // AI
  aiSummary        String?
  aiConfidence     Float?
  aiCategory       String?
  aiSuggestedTitle String?
  aiExtractedData  Json?
  aiProcessedAt    DateTime?

  // AI Conversation Log
  aiConversationLog AIConversationLog?

  // Channel specific references
  whatsappMessages WhatsAppMessage[]
  phoneCalls        PhoneCall[]
  webChatSessions   WebChatSession[]

  is_active  Boolean   @default(true)
  deletedAt DateTime?
  @@index([deletedAt])

  @@index([companyId])
  @@index([customerId])
  @@index([assignedUserId])
  @@index([status])
  @@index([priority])
}

enum TicketStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  HEATING
  PLUMBING
  ELECTRICITY
  PAINTING
  OTHER
}

enum TicketSource {
  WEB_CHAT
  PHONE
  WHATSAPP
  EMAIL
}

model Appointment {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  employeeId String?
  employee   User?   @relation(fields: [employeeId], references: [id])

  title       String
  description String?

  status AppointmentStatus @default(PLANNED)

  startAt DateTime
  endAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  is_active  Boolean   @default(true)
  deletedAt DateTime? 
  @@index([deletedAt])

  @@index([companyId])
  @@index([customerId])
  @@index([employeeId])
  @@index([startAt])
}

enum AppointmentStatus {
  PLANNED
  COMPLETED
  CANCELLED
}

model ActivityLog {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action String

  entityType String
  entityId   String?

  metadata Json?

  ipAddress String?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

model EmailInbox {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  messageId String @unique

  fromEmail String
  fromName  String?

  subject String

  body String

  processed Boolean @default(false)

  processingError String?

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([processed])
  @@index([createdAt])
}

model Notification {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  title   String
  message String?

  type NotificationType

  isRead Boolean @default(false)

  entityType String?
  entityId   String?

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum Locale {
  EN
  DE
  FR
  RU
  TR
}

// AI Conversation Log - Ticket ile ilişkilendirilmiş konuşmalar
model AIConversationLog {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  ticketId String? @unique
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  channelType TicketSource

  // Konuşma detayları
  conversationType ConversationType
  startTime DateTime
  endTime DateTime?

  // Medya referansları
  audioRecordingUrl String?   // Telefon için ses kaydı
  chatLog Json?              // Konuşma geçmişi
  originalEmailId String?    // Email için referans

  // AI işleme sonuçları
  aiIntent String?
  aiConfidence Float?
  aiExtractedEntities Json?

  // Channel specific relations
  whatsappMessages WhatsAppMessage[]
  phoneCalls        PhoneCall[]
  webChatSessions   WebChatSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([ticketId])
  @@index([channelType])
  @@index([createdAt])
}

enum ConversationType {
  INITIAL_INQUIRY
  INFORMATION_GATHERING
  APPOINTMENT_SCHEDULING
  ISSUE_RESOLUTION
  FOLLOW_UP
}

// WhatsApp Message
model WhatsAppMessage {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  conversationLogId String?
  conversationLog   AIConversationLog? @relation(fields: [conversationLogId], references: [id])

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  phoneNumber String
  messageFrom String  // 'customer' or 'assistant'
  content String

  mediaUrl String?
  mediaType String?

  whatsappMessageId String @unique

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([ticketId])
  @@index([phoneNumber])
  @@index([createdAt])
}

// Phone Call
model PhoneCall {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  conversationLogId String?
  conversationLog   AIConversationLog? @relation(fields: [conversationLogId], references: [id])

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  phoneNumber String
  direction CallDirection
  duration Int?

  recordingUrl String?
  transcription String?

  callStatus CallStatus

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([ticketId])
  @@index([phoneNumber])
  @@index([createdAt])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  COMPLETED
  MISSED
  CANCELLED
}

// Web Chat Session
model WebChatSession {
  id String @id @default(cuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  conversationLogId String?
  conversationLog   AIConversationLog? @relation(fields: [conversationLogId], references: [id])

  ticketId String?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  sessionId String @unique
  customerEmail String?
  customerName String?

  ipAddress String?
  userAgent String?

  status ChatStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([ticketId])
  @@index([sessionId])
  @@index([createdAt])
}

enum ChatStatus {
  ACTIVE
  CLOSED
  TRANSFERRED
}

// Parameter Tables

model Bank {
  id        String    @id @default(cuid())
  name      String
  address   String
  email     String
  phoneNumber String
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  bankAccounts BankAccount[]

  @@index([deletedAt])
}

model BankAccount {
  id          String   @id @default(cuid())
  bankId      String
  bank        Bank     @relation(fields: [bankId], references: [id])
  currencyId  String
  currency    Currency @relation(fields: [currencyId], references: [id])
  currencyCode String
  iban        String
  swiftNumber String
  isDeleted   Boolean  @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime @default(now())
  createdBy   String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([deletedAt])
  @@index([bankId])
  @@index([currencyId])
}

model CustomerAuthority {
  id        String    @id @default(cuid())
  name      String
  email     String
  title     String
  gsm       String
  phone     String
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  @@index([deletedAt])
}

model Employee {
  id          String    @id @default(cuid())
  name        String
  email       String
  phoneNumber String
  address     String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?

  @@index([deletedAt])
  @@index([departmentId])
}

model TaxOffice {
  id                 String   @id @default(cuid())
  plateCode          String
  name               String
  districtName       String
  muhasebeBirimiKodu String   @unique
  taxOfficeName      String
  isDeleted          Boolean  @default(false)
  deletedAt          DateTime?
  deletedBy          String?
  createdAt          DateTime @default(now())
  createdBy          String?
  updatedAt          DateTime @updatedAt
  updatedBy          String?

  @@index([deletedAt])
  @@index([plateCode])
  @@index([muhasebeBirimiKodu])
}

model Department {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  employees Employee[]

  @@index([deletedAt])
}

model CustomerType {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  @@index([deletedAt])
}

model CargoFirm {
  id          String    @id @default(cuid())
  name        String
  email       String
  phoneNumber String
  address     String
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?

  @@index([deletedAt])
}

model SaleType {
  id        String    @id @default(cuid())
  name      String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  @@index([deletedAt])
}

model Currency {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  symbol    String
  isActive  Boolean   @default(true)
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  createdBy String?
  updatedAt DateTime  @updatedAt
  updatedBy String?

  bankAccounts BankAccount[]

  @@index([deletedAt])
}

// ============================================
// ÜRÜN YÖNETİMİ (PRODUCT MANAGEMENT)
// ============================================

enum ProductUnit {
  PIECE     // Adet
  KG        // Kilogram
  M         // Metre
  M2        // Metrekare
  M3        // Metreküp
  LT        // Litre
  SET       // Set
  BOX       // Kutu
  PACKAGE   // Paket
}

model ProductCategory {
  id          String    @id @default(cuid())
  companyId   String
  name        String
  description String?
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?

  products Product[]

  @@index([companyId])
  @@index([deletedAt])
}

model Product {
  id          String         @id @default(cuid())
  companyId   String
  code        String
  name        String
  description String?
  categoryId  String?
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  unit        ProductUnit    @default(PIECE)
  
  // Fiyat bilgileri
  purchasePrice String?  // Decimal as String for SQLite
  salePrice     String   // Decimal as String for SQLite
  taxRate       String   @default("0")  // Decimal as String for SQLite
  
  // Stok bilgileri
  currentStock  Int           @default(0)
  minStock      Int           @default(0)
  maxStock      Int?
  
  // Ürün özellikleri
  barcode       String?
  imageUrl      String?
  
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?

  stockMovements StockMovement[]
  orderItems     OrderItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([categoryId])
  @@index([deletedAt])
}

// ============================================
// STOK TAKİBİ (STOCK MANAGEMENT)
// ============================================

enum StockMovementType {
  IN        // Giriş
  OUT       // Çıkış
  TRANSFER  // Transfer
  ADJUSTMENT // Düzeltme
}

model StockMovement {
  id          String            @id @default(cuid())
  companyId   String
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  type        StockMovementType
  quantity    Int
  
  // İşlem öncesi ve sonrası stok
  stockBefore Int
  stockAfter  Int
  
  // Referans bilgileri
  referenceType String?  // ORDER, PURCHASE, MANUAL, etc.
  referenceId   String?
  
  notes       String?
  
  createdAt   DateTime  @default(now())
  createdBy   String?

  @@index([companyId])
  @@index([productId])
  @@index([createdAt])
}

// ============================================
// SATIŞ / SİPARİŞ (ORDERS/SALES)
// ============================================

enum OrderStatus {
  DRAFT           // Taslak
  PENDING         // Beklemede
  CONFIRMED       // Onaylandı
  PROCESSING      // İşleniyor
  SHIPPED         // Kargoya verildi
  DELIVERED       // Teslim edildi
  COMPLETED       // Tamamlandı
  CANCELLED       // İptal edildi
}

enum PaymentStatus {
  UNPAID          // Ödenmedi
  PARTIAL         // Kısmi ödendi
  PAID            // Ödendi
  REFUNDED        // İade edildi
}

model Order {
  id            String        @id @default(cuid())
  companyId     String
  orderNumber   String
  
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  
  // Sipariş bilgileri
  orderDate     DateTime      @default(now())
  deliveryDate  DateTime?
  status        OrderStatus   @default(DRAFT)
  paymentStatus PaymentStatus @default(UNPAID)
  
  // Tutar bilgileri (Decimal as String for SQLite)
  subtotal       String
  taxAmount      String  @default("0")
  discountAmount String  @default("0")
  shippingCost   String  @default("0")
  totalAmount    String
  
  // Adres ve notlar
  shippingAddress String?
  billingAddress  String?
  notes           String?
  
  isActive    Boolean   @default(true)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  deletedBy   String?
  createdAt   DateTime  @default(now())
  createdBy   String?
  updatedAt   DateTime  @updatedAt
  updatedBy   String?

  orderItems OrderItem[]

  @@unique([companyId, orderNumber])
  @@index([companyId])
  @@index([customerId])
  @@index([orderDate])
  @@index([status])
  @@index([deletedAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  quantity    Int
  unitPrice   String  // Decimal as String for SQLite
  taxRate     String  @default("0")  // Decimal as String for SQLite
  discount    String  @default("0")  // Decimal as String for SQLite
  
  // Hesaplanan tutarlar (Decimal as String for SQLite)
  subtotal    String  // quantity * unitPrice
  taxAmount   String
  totalAmount String
  
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}
